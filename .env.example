BOT_TOKEN=your_telegram_bot_token_here
DEVELOPER_HANDLE=your_telegram_handle
CHANNEL_ID=BerlinFlatsAll
# Local dev: sqlite+aiosqlite:///./berlin_flats.db
# Production (Fly.io): sqlite+aiosqlite:////data/berlin_flats.db  ← set in fly.toml [env]
DATABASE_URL=sqlite+aiosqlite:///./berlin_flats.db
SCRAPE_INTERVAL_MINUTES=30
LOG_LEVEL=INFO
# Optional: ScrapFly API key to enable ImmobilienScout24 scraping (bypasses Cloudflare)
# Get one at https://scrapfly.io — free tier includes 1000 API calls/month
SCRAPFLY_KEY=
